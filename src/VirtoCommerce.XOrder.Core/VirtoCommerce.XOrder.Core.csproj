<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <IsPackable>True</IsPackable>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.0.0" PrivateAssets="All" />
    <PackageReference Include="VirtoCommerce.OrdersModule.Core" Version="3.867.0-alpha.1395-variation-configuration-type" />
    <PackageReference Include="VirtoCommerce.PaymentModule.Core" Version="3.812.0" />
    <PackageReference Include="VirtoCommerce.Xapi.Core" Version="3.929.0" />
    <PackageReference Include="VirtoCommerce.XCart.Core" Version="3.953.0-alpha.201-variation-configuration-type" />
    <PackageReference Include="VirtoCommerce.XCatalog.Core" Version="3.942.0" />
  </ItemGroup>
</Project>
